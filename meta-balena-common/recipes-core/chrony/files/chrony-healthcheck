#!/bin/bash

set -o errexit

. /usr/libexec/os-helpers-logging

# Include unresolved sources (-a) so configured-but-not-yet-resolved
# pools are not mistaken for an empty source set.
source_states=$(chronyc -n sources -a | tail -n +3 | awk '{ print $1 }')

# No sources configured (e.g. ntpServers "null" and no DHCP Option 42):
# treat as healthy so the watchdog does not restart chronyd in a loop.
if [ -z "${source_states}" ]; then
	info "No NTP sources configured - skipping sync check"
	exit 0
fi

offline="true"
for source in $source_states; do
	if [[ $source = *\** ]]; then
		offline="false"
	fi
done

if [ "${offline}" = "true" ]; then
	info "No online NTP sources - forcing poll"

	if ! /usr/bin/chronyc 'burst 4/4' > /dev/null ||
		 ! /usr/bin/chronyc makestep > /dev/null; then
		error "Failed to trigger NTP sync"
		exit 1
	fi
fi

if ! /usr/bin/chronyc waitsync 60 0.1 0.0 1; then
	error "NTP time lost synchronization - restarting chronyd"
	exit 1
fi
