#!/bin/sh
#
# kernel-override-hooks: activate hook
#
# Verifies the install symlink resolves and is non-empty, then writes
# kernel_override_abi, sets upgrade_available=1, and resets bootcount=0
# — engaging the existing HUP-style rollback machinery.

set -eu

# shellcheck disable=SC1091
. /usr/libexec/os-helpers-logging
# shellcheck disable=SC1091
. /usr/libexec/os-helpers-bootenv
# shellcheck disable=SC1091
. /usr/libexec/os-helpers-extensions

BOOT_BY_ABI_DIR="/mnt/data/boot-by-abi"

extension_kernel_override_prelude "${EXTENSION_ROOTFS}" || exit 0

KERNEL_IMG_NAME=$(basename "${EXTENSION_KERNEL_IMG}")

TARGET="${BOOT_BY_ABI_DIR}/${EXTENSION_KERNEL_ABI_ID}"
if ! { [ -L "${TARGET}" ] && [ -e "${TARGET}/${KERNEL_IMG_NAME}" ]; }; then
    fail "boot-by-abi/${EXTENSION_KERNEL_ABI_ID} missing or ${KERNEL_IMG_NAME} not present; aborting activation"
fi

BOOTENV_FILE=$(bootenv_locate) || fail "cannot locate bootenv"

bootenv_set "${BOOTENV_FILE}" "bootcount" "0"
bootenv_set "${BOOTENV_FILE}" "upgrade_available" "1"
# Must be last
bootenv_set "${BOOTENV_FILE}" "kernel_override_abi" "${EXTENSION_KERNEL_ABI_ID}"
sync
info "activated kernel override; ABI=${EXTENSION_KERNEL_ABI_ID}"
