#
# Single-key get/set/unset helpers for a grub-env bootloader file.
# POSIX /bin/sh compatible; safe to source from busybox sh (initrd) and
# the host OS.
#

# bootenv_get <file> <key>
#   Prints the value of <key> on stdout if present; prints nothing if
#   the key is unset, the file is missing, or grub-editenv is
#   unavailable. Return code is always 0 — callers distinguish
#   "unset" from "set to empty" by inspecting the printed value.
bootenv_get() {
    _file="$1"
    _key="$2"
    [ -n "${_file}" ] && [ -f "${_file}" ] || return 0
    [ -n "${_key}" ] || return 0
    command -v grub-editenv >/dev/null 2>&1 || return 0
    grub-editenv "${_file}" list 2>/dev/null | sed -n "s/^${_key}=//p"
}

# bootenv_set <file> <key> <value>
bootenv_set() {
    grub-editenv "$1" set "$2=$3"
}

# bootenv_unset <file> <key>
bootenv_unset() {
    grub-editenv "$1" unset "$2"
}

# bootenv_commit_override <file> <slot>
#   Record the active kernel override as <slot>'s committed override.
bootenv_commit_override() {
    _f="$1"
    _slot="$2"
    grub-editenv "${_f}" set \
        bootcount=0 \
        upgrade_available=0 \
        "kernel_override_abi_committed_${_slot}=$(bootenv_get "${_f}" "kernel_override_abi")"
}

# bootenv_restore_kernel_override <file> <slot>
#   Roll the active override back to <slot>'s last committed one.
#   An empty/unset committed value clears the override so the device
#   boots the stock kernel.
bootenv_restore_kernel_override() {
    _f="$1"
    _slot="$2"
    _committed=$(bootenv_get "${_f}" "kernel_override_abi_committed_${_slot}")
    if [ -n "${_committed}" ]; then
        bootenv_set "${_f}" "kernel_override_abi" "${_committed}"
    else
        bootenv_unset "${_f}" "kernel_override_abi"
    fi
}

# bootenv_locate [mountpoint]
#   Locates a grub-env file under <mountpoint> (defaults to
#   ${BALENA_NONENC_BOOT_MOUNTPOINT}, then to discovery via the canonical
#   boot-partition by-state symlink). Prints the path and returns 0 if found,
#   returns 1 otherwise.
#
bootenv_locate() {
    _mp="${1:-${BALENA_NONENC_BOOT_MOUNTPOINT:-}}"
    if [ -z "${_mp}" ]; then
        command -v get_state_path_from_label >/dev/null 2>&1 || . /usr/libexec/os-helpers-fs
        _dev=$(get_state_path_from_label "resin-boot")
        [ -n "${_dev}" ] && _mp=$(findmnt -n -o TARGET --source "${_dev}" 2>/dev/null | head -n1)
    fi
    [ -n "${_mp}" ] || return 1
    if [ -f "${_mp}/bootenv" ]; then
        echo "${_mp}/bootenv"
        return 0
    fi
    _found=$(find -L "${_mp}" -maxdepth 3 \
        \( -name 'bootenv' -o -name 'grubenv' \) 2>/dev/null | head -n1)
    [ -n "${_found}" ] || return 1
    echo "${_found}"
}
