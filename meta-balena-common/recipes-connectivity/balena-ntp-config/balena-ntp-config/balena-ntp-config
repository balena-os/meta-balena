#!/bin/sh
#
# Update NTP sources from config.json
#

set -e

. /usr/sbin/balena-config-vars

SERVER_DIR=/run/chrony
SERVER_FILE=${SERVER_DIR}/balena-ntp.sources
DEFAULT_NTP_SERVERS="0.resinio.pool.ntp.org 1.resinio.pool.ntp.org 2.resinio.pool.ntp.org 3.resinio.pool.ntp.org"

if [ ! -f "$CONFIG_PATH" ]; then
	echo "balena-ntp-config: $CONFIG_PATH does not exist."
	exit 1
else
	echo "balena-ntp-config: Found config.json in $CONFIG_PATH ."
fi

if [ ! -d "$SERVER_DIR" ]; then
	mkdir -p $SERVER_DIR -m 770
fi

# Always remove the old server file before we refresh the list.
rm -f "$SERVER_FILE"

# Trim surrounding whitespace so the any variant of "null" and spaces match
NTP_SERVERS=$(printf '%s' "$NTP_SERVERS" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

add_servers() {
	local servers=$1
	for server in $servers; do
		echo "pool $server iburst minpoll 14 maxpoll 14 maxsources 1" >> "$SERVER_FILE"
	done
}

if [ "$NTP_SERVERS" = "null" ]; then
	echo "balena-ntp-config: Default NTP sources disabled via config.json"
elif [ -n "$NTP_SERVERS" ]; then
	echo "Adding NTP sources (config.json)"
	add_servers "$NTP_SERVERS"
else
	echo "balena-ntp-config: Using default NTP sources"
	add_servers "$DEFAULT_NTP_SERVERS"
fi

# Always update the sources as they may have been added or removed.
/usr/libexec/chrony-helper update-sources || true

exit 0
